# Example environment variables for the Netweave projects
# Copy this file to `.env` at the root of the workspace and fill in real values.

# API key used by MailService when calling the resend.com endpoint
RESEND_API_KEY=your_real_resend_api_key_here

NODE_ENV=production # node.js environment

PORT=3000 # HTTP port the API listens on (needs to be 3000 at the moment, has to be changed in other places if changed here)

LOG_DIR=/app/logs # directory where the log file with api responses is saved; use LOG_DIR=/apps/logs (absolute path) in Docker; use LOG_DIR=./apps/netweave-api (relative path) for local development

CRON_SCHEDULE_API_FETCH=*/1 * * * * # every minute by default

CRON_SCHEDULE_MAIL_SEND=*/1 * * * * # every minute by default
